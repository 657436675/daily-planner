{
  "id": "exam-sprint",
  "name": "考试冲刺",
  "target": "考研考公考证人群",
  "description": "有限时间内拿下考试，用每日刷题+复盘来保证进度",
  "questions": [
    {
      "group": "考试信息",
      "items": [
        "你要考什么？什么时候考？还剩多少天？",
        "考哪些科目？哪个科目最弱？",
        "你的目标分数/通过标准是什么？"
      ]
    },
    {
      "group": "基础评估",
      "items": [
        "你现在的水平大概在什么位置？（零基础/有一定基础/已复习一轮）",
        "有没有报班或买了资料？",
        "之前考过吗？考了多少？"
      ]
    },
    {
      "group": "时间安排",
      "items": [
        "每天能拿出多少时间复习？全职还是兼职备考？",
        "有没有固定学习时段？（上午/下午/晚上）",
        "还有其他事情要兼顾吗？（工作/课程/家庭）"
      ]
    }
  ],
  "levels": [
    {
      "lv": 1,
      "name": "备考新手",
      "min": 0
    },
    {
      "lv": 2,
      "name": "基础巩固",
      "min": 500
    },
    {
      "lv": 3,
      "name": "进阶刷题",
      "min": 1500
    },
    {
      "lv": 4,
      "name": "冲刺选手",
      "min": 3000
    },
    {
      "lv": 5,
      "name": "模考达人",
      "min": 5000
    },
    {
      "lv": 6,
      "name": "临阵磨枪",
      "min": 8000
    },
    {
      "lv": 7,
      "name": "上岸达人",
      "min": 12000
    }
  ],
  "categories": {
    "morning": {
      "label": "晨间记忆",
      "color": "#f59e0b"
    },
    "core": {
      "label": "核心刷题",
      "color": "#ef4444"
    },
    "review": {
      "label": "复盘总结",
      "color": "#3b82f6"
    },
    "evening": {
      "label": "晚间巩固",
      "color": "#22c55e"
    }
  },
  "defaultTasks": [
    {
      "id": "dt_1",
      "cat": "morning",
      "title": "起床打卡",
      "xp": 10,
      "desc": "固定时间起床，保证学习时间"
    },
    {
      "id": "dt_2",
      "cat": "morning",
      "title": "记忆背诵 30分钟",
      "xp": 15,
      "desc": "背诵知识点/公式/单词"
    },
    {
      "id": "dt_3",
      "cat": "core",
      "title": "弱科专项攻克",
      "xp": 30,
      "desc": "重点攻克最弱的科目/章节"
    },
    {
      "id": "dt_4",
      "cat": "core",
      "title": "刷题练习",
      "xp": 25,
      "desc": "做练习题/真题/模拟题"
    },
    {
      "id": "dt_5",
      "cat": "core",
      "title": "错题整理",
      "xp": 15,
      "desc": "把错题归因并记录到错题本"
    },
    {
      "id": "dt_6",
      "cat": "review",
      "title": "复盘总结",
      "xp": 15,
      "desc": "总结今天学了什么，哪里卡住"
    },
    {
      "id": "dt_7",
      "cat": "review",
      "title": "知识框架梳理",
      "xp": 15,
      "desc": "画思维导图/整理笔记框架"
    },
    {
      "id": "dt_8",
      "cat": "evening",
      "title": "睡前回忆",
      "xp": 10,
      "desc": "睡前回忆今天学过的3个核心知识点"
    },
    {
      "id": "dt_9",
      "cat": "evening",
      "title": "运动 30分钟",
      "xp": 15,
      "desc": "运动放松，保持大脑活力"
    },
    {
      "id": "dt_10",
      "cat": "evening",
      "title": "入睡打卡",
      "xp": 10,
      "desc": "保证充足睡眠，明天才有精力"
    }
  ],
