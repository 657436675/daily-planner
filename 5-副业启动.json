{
  "id": "side-hustle",
  "name": "副业启动",
  "target": "职场人/自由职业者",
  "description": "从0开始跑通一个副业，用每日推进来保证从想法到收入",
  "questions": [
    {
      "group": "方向确认",
      "items": [
        "你想做什么副业？（咨询/写作/设计/电商/自媒体/技术接单……）",
        "你有相关的技能基础吗？还是需要先学？",
        "你为什么想做副业？（增加收入/试水新方向/未来全职转型……）"
      ]
    },
    {
      "group": "资源评估",
      "items": [
        "你每天能拿出多少时间做副业？（白天/晚上/周末）",
        "你有什么可以用的资源？（人脉/技能/设备/资金……）",
        "你主业是什么？副业和主业有没有冲突？"
      ]
    },
    {
      "group": "期望管理",
      "items": [
        "你期望多久开始有收入？",
        "第一个月的目标收入是多少？（合理预期）",
        "如果3个月没收入，你会放弃还是坚持？"
      ]
    }
  ],
  "levels": [
    {
      "lv": 1,
      "name": "副业新手",
      "min": 0
    },
    {
      "lv": 2,
      "name": "探索者",
      "min": 500
    },
    {
      "lv": 3,
      "name": "起步者",
      "min": 1500
    },
    {
      "lv": 4,
      "name": "破零者",
      "min": 3000
    },
    {
      "lv": 5,
      "name": "稳定者",
      "min": 5000
    },
    {
      "lv": 6,
      "name": "增长者",
      "min": 8000
    },
    {
      "lv": 7,
      "name": "独立创收",
      "min": 12000
    }
  ],
  "categories": {
    "morning": {
      "label": "晨间准备",
      "color": "#f59e0b"
    },
    "core": {
      "label": "核心推进",
      "color": "#ef4444"
    },
    "growth": {
      "label": "获客运营",
      "color": "#3b82f6"
    },
    "evening": {
      "label": "晚间复盘",
      "color": "#22c55e"
    }
  },
  "defaultTasks": [
    {
      "id": "dt_1",
      "cat": "morning",
      "title": "起床打卡",
      "xp": 10,
      "desc": "固定时间起床，保证副业时间"
    },
    {
      "id": "dt_2",
      "cat": "morning",
      "title": "学习 30分钟",
      "xp": 15,
      "desc": "学习副业方向相关技能或市场知识"
    },
    {
      "id": "dt_3",
      "cat": "core",
      "title": "产品/服务打磨",
      "xp": 30,
      "desc": "打磨你的副业产品或服务"
    },
    {
      "id": "dt_4",
      "cat": "core",
      "title": "内容产出",
      "xp": 20,
      "desc": "写文章/做视频/做设计等产出"
    },
    {
      "id": "dt_5",
      "cat": "core",
      "title": "MVP推进",
      "xp": 25,
      "desc": "推进最小可用版本的开发/搭建"
    },
    {
      "id": "dt_6",
      "cat": "growth",
      "title": "获客行动",
      "xp": 15,
      "desc": "发内容/回复评论/联系潜在客户"
    },
    {
      "id": "dt_7",
      "cat": "growth",
      "title": "平台运营",
      "xp": 15,
      "desc": "维护社交媒体/店铺/个人网站"
    },
    {
      "id": "dt_8",
      "cat": "growth",
      "title": "客户跟进",
      "xp": 15,
      "desc": "跟进已有咨询/订单/合作"
    },
    {
      "id": "dt_9",
      "cat": "evening",
      "title": "日复盘",
      "xp": 10,
      "desc": "今天推进了什么？离目标近了多少？"
    },
    {
      "id": "dt_10",
      "cat": "evening",
      "title": "运动 30分钟",
      "xp": 15,
      "desc": "运动放松，保持精力"
    },
    {
      "id": "dt_11",
      "cat": "evening",
      "title": "入睡打卡",
      "xp": 10,
      "desc": "在目标时间前放下手机"
    }
  ],
  "achievements": [
    {
      "id": "a1",
      "name": "初次打卡",
      "desc": "完成第一个任务"
    },
    {
      "id": "a2",
      "name": "半程选手",
      "desc": "单日完成50%任务"
    },
    {
      "id": "a3",
      "name": "全勤日",
      "desc": "单日完成全部任务"
    },
    {
      "id": "a4",
      "name": "连续3天",
      "desc": "连续3天至少完成1个任务"
    },
    {
      "id": "a5",
      "name": "连续7天",
      "desc": "连续7天打卡"
    },
    {
      "id": "a6",
      "name": "连续14天",
      "desc": "连续14天打卡"
    },
    {
      "id": "a7",
      "name": "连续30天",
      "desc": "坚持30天不间断"
    },
    {
      "id": "a8",
      "name": "早起鸟",
      "desc": "连续7天完成起床任务"
    },
    {
      "id": "a9",
      "name": "首发",
      "desc": "产出第一篇内容/第一个产品"
    },
    {
      "id": "a10",
      "name": "首客",
      "desc": "获得第一个客户/咨询"
    },
    {
      "id": "a11",
      "name": "首单",
      "desc": "获得第一笔收入"
    },
    {
      "id": "a12",
      "name": "破千",
      "desc": "累计副业收入破1000元"
    },
    {
      "id": "a13",
      "name": "等级5",
      "desc": "达到Lv.5 稳定者"
    },
    {
      "id": "a14",
      "name": "稳定收入",
      "desc": "连续2周有收入"
    }
  ],
  "dayThemes": {
    "0": {
      "title": "周日 · 休息日",
      "desc": "轻度思考即可，不强制产出",
      "color": "#64748b"
    },
    "1": {
      "title": "周一 · 规划日",
      "desc": "确定本周目标，列出待办",
      "color": "#1e40af"
    },
    "2": {
      "title": "周二 · 产出日",
      "desc": "专注内容/产品产出",
      "color": "#ef4444"
    },
    "3": {
      "title": "周三 · 实验日",
      "desc": "测试新方法/新渠道/新定价",
      "color": "#0f6e56"
    },
    "4": {
      "title": "周四 · 获客日",
      "desc": "重点做获客和客户沟通",
      "color": "#3b82f6"
    },
    "5": {
      "title": "周五 · 复盘日",
      "desc": "复盘本周数据，调整策略",
      "color": "#f59e0b"
    },
    "6": {
      "title": "周六 · 深度日",
      "desc": "做需要长时间投入的深度工作",
      "color": "#22c55e"
    }
  },
  "footerText": "副业从0到1是最难的阶段。每天推进一点，破零只是时间问题。"
}